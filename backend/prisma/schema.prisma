generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Empresa {
  idEmpresa  Int         @id @default(autoincrement()) @map("id_empresa")
  nombre     String      @db.VarChar(100)
  rutEmpresa String?     @unique @map("rut_empresa") @db.VarChar(12)
  esquemaDb  String?     @map("esquema_db") @db.VarChar(50)
  usuarios   Usuario[]
  clientes   Cliente[]
  prospectos Prospecto[]
  planes     Plan[]

  @@map("empresa")
}

model Usuario {
  idUsuario          Int             @id @default(autoincrement()) @map("id_usuario")
  idEmpresa          Int?            @map("id_empresa")
  nombreCompleto     String          @map("nombre_completo") @db.VarChar(80)
  nombreUsuario      String?         @unique @map("nombre_usuario") @db.VarChar(50)
  email              String?         @unique @db.VarChar(120)
  passwordHash       String          @map("password_hash") @db.VarChar(72)
  activo             Boolean?        @default(true)
  fechaCreacion      DateTime?       @default(now()) @map("fecha_creacion")
  esPasswordTemporal Boolean?        @default(true) @map("es_password_temporal")
  intentosFallidos   Int?            @default(0) @map("intentos_fallidos")
  empresa            Empresa?        @relation(fields: [idEmpresa], references: [idEmpresa])
  usuarioRoles       UsuarioRol[]
  auditorias         LogAuditoria[]
  prospectos         Prospecto[]

  @@map("usuario")
}

model Rol {
  idRol        Int          @id @default(autoincrement()) @map("id_rol")
  nombreRol    String       @unique @map("nombre_rol") @db.VarChar(50)
  descripcion  String?
  usuarioRoles UsuarioRol[]

  @@map("rol")
}

model UsuarioRol {
  idUsuarioRol    Int       @id @default(autoincrement()) @map("id_usuario_rol")
  idUsuario       Int?      @map("id_usuario")
  idRol           Int       @map("id_rol")
  fechaAsignacion DateTime? @default(now()) @map("fecha_asignacion") @db.Date
  usuario         Usuario?  @relation(fields: [idUsuario], references: [idUsuario])
  rol             Rol       @relation(fields: [idRol], references: [idRol])

  @@unique([idUsuario, idRol])
  @@map("usuario_rol")
}

model LogAuditoria {
  idLog             BigInt    @id @default(autoincrement()) @map("id_log")
  idUsuario         Int?      @map("id_usuario")
  accion            String    @db.VarChar(100)
  entidadAfectada   String?   @map("entidad_afectada") @db.VarChar(80)
  idEntidadAfectada Int?      @map("id_entidad_afectada")
  valorAnterior     Json?     @map("valor_anterior")
  valorNuevo        Json?     @map("valor_nuevo")
  ipOrigen          String?   @map("ip_origen") @db.Inet
  fechaHora         DateTime? @default(now()) @map("fecha_hora")
  usuario           Usuario?  @relation(fields: [idUsuario], references: [idUsuario])

  @@map("log_auditoria")
}

model Cliente {
  idCliente          Int         @id @default(autoincrement()) @map("id_cliente")
  idEmpresa          Int?        @map("id_empresa")
  rut                String?     @unique @db.VarChar(12)
  nombreCompleto     String      @map("nombre_completo") @db.VarChar(120)
  email              String?     @db.VarChar(120)
  telefono           String?     @db.VarChar(20)
  passwordPortalHash String?     @map("password_portal_hash") @db.VarChar(72)
  estado             String      @db.VarChar(20)
  esConflictivo      Boolean?    @default(false) @map("es_conflictivo")
  importadoMasivo    Boolean?    @default(false) @map("importado_masivo")
  obsConflictivo     String?     @map("obs_conflictivo")
  fechaCreacion      DateTime?   @default(now()) @map("fecha_creacion")
  empresa            Empresa?    @relation(fields: [idEmpresa], references: [idEmpresa])
  prospecto          Prospecto?
  contratos          Contrato[]
  direcciones        DireccionServicio[]

  @@map("cliente")
}

model Prospecto {
  idProspecto           Int       @id @default(autoincrement()) @map("id_prospecto")
  idEmpresa             Int?      @map("id_empresa")
  idUsuarioComercial    Int?      @map("id_usuario_comercial")
  idCliente             Int?      @unique @map("id_cliente")
  rut                   String?   @db.VarChar(12)
  nombreCompleto        String?   @map("nombre_completo") @db.VarChar(120)
  email                 String?   @db.VarChar(120)
  telefono              String?   @db.VarChar(20)
  direccion             String?   @db.VarChar(200)
  estadoPipeline        String?   @map("estado_pipeline") @db.VarChar(30)
  motivoPerdida         String?   @map("motivo_perdida") @db.VarChar(30)
  tiempoConversionDias  Int?      @map("tiempo_conversion_dias")
  fechaCreacion         DateTime? @map("fecha_creacion")
  fechaConversion       DateTime? @map("fecha_conversion") @db.Date
  empresa               Empresa?  @relation(fields: [idEmpresa], references: [idEmpresa])
  usuarioComercial      Usuario?  @relation(fields: [idUsuarioComercial], references: [idUsuario])
  cliente               Cliente?  @relation(fields: [idCliente], references: [idCliente])
  cotizaciones          Cotizacion[]

  @@map("prospecto")
}

model Plan {
  idPlan          Int          @id @default(autoincrement()) @map("id_plan")
  idEmpresa       Int?         @map("id_empresa")
  nombreComercial String       @map("nombre_comercial") @db.VarChar(100)
  tipoPlan        String       @map("tipo_plan") @db.VarChar(20)
  tipoCliente     String       @map("tipo_cliente") @db.VarChar(20)
  velocidadMbps   Int?         @map("velocidad_mbps")
  precioMensual   Decimal      @map("precio_mensual") @db.Decimal(10, 2)
  descripcion     String?
  activo          Boolean?     @default(true)
  empresa         Empresa?     @relation(fields: [idEmpresa], references: [idEmpresa])
  cotizaciones    Cotizacion[]
  contratos       Contrato[]

  @@map("plan")
}

model Cotizacion {
  idCotizacion           Int        @id @default(autoincrement()) @map("id_cotizacion")
  idProspecto            Int?       @map("id_prospecto")
  idPlan                 Int?       @map("id_plan")
  pdfUrl                 String?    @map("pdf_url")
  fechaEnvio             DateTime?  @map("fecha_envio")
  factibilidadVerificada Boolean?   @default(false) @map("factibilidad_verificada")
  prospecto              Prospecto? @relation(fields: [idProspecto], references: [idProspecto])
  plan                   Plan?      @relation(fields: [idPlan], references: [idPlan])

  @@map("cotizacion")
}

model Contrato {
  idContrato      Int       @id @default(autoincrement()) @map("id_contrato")
  idCliente       Int?      @map("id_cliente")
  idPlan          Int?      @map("id_plan")
  idEmpresa       Int?      @map("id_empresa")
  fechaInicio     DateTime  @map("fecha_inicio") @db.Date
  diaVencimiento  Int       @map("dia_vencimiento") @db.SmallInt
  estado          String    @db.VarChar(20)
  fechaSuspension DateTime? @map("fecha_suspension") @db.Date
  cliente         Cliente?  @relation(fields: [idCliente], references: [idCliente])
  plan            Plan?     @relation(fields: [idPlan], references: [idPlan])

  @@map("contrato")
}

model DireccionServicio {
  idDireccion       Int      @id @default(autoincrement()) @map("id_direccion")
  idCliente         Int?     @map("id_cliente")
  direccionCompleta String   @map("direccion_completa") @db.VarChar(200)
  comuna            String   @db.VarChar(80)
  ciudad            String?  @db.VarChar(80)
  esPrincipal       Boolean? @default(true) @map("es_principal")
  cliente           Cliente? @relation(fields: [idCliente], references: [idCliente])

  @@map("direccion_servicio")
}

model OrdenTrabajo {
  idOt                Int       @id @default(autoincrement()) @map("id_ot")
  idEmpresa           Int?      @map("id_empresa")
  idCliente           Int?      @map("id_cliente")
  idTecnico           Int?      @map("id_tecnico")
  idTecnicoExterno    Int?      @map("id_tecnico_externo")
  idDireccion         Int?      @map("id_direccion")
  idTicket            Int?      @unique @map("id_ticket")
  tipoOt              String    @map("tipo_ot") @db.VarChar(20)
  prioridad           String    @db.VarChar(10)
  estado              String    @db.VarChar(25)
  fechaCreacion       DateTime? @map("fecha_creacion")
  fechaProgramada     DateTime? @map("fecha_programada") @db.Date
  fechaCompletada     DateTime? @map("fecha_completada")
  potenciaOpticaDbm   Decimal?  @map("potencia_optica_dbm") @db.Decimal(5, 2)
  observaciones       String?
  resueltoRemotamente Boolean?  @default(false) @map("resuelto_remotamente")

  @@map("orden_trabajo")
}
