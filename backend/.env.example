DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fsm_db?schema=public
JWT_SECRET=change_me_in_local_env
JWT_EXPIRES_IN=8h
PORT=3000
# Use comma-separated origins if the backend is exposed directly.
FRONTEND_URL=http://localhost:5173

# Correo de cotizaciones (SMTP). Dejar SMTP_HOST vacio desactiva el envio.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_STARTTLS=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_FROM_NAME=CRM FiNet
