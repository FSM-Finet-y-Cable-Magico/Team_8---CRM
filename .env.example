POSTGRES_DB=fsm_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fsm_db?schema=public
JWT_SECRET=change_me_in_local_env
JWT_EXPIRES_IN=8h

BACKEND_PORT=3000
FRONTEND_PORT=5173
VITE_API_URL=/api
API_PROXY_TARGET=http://127.0.0.1:3000

# Correo de cotizaciones (SMTP). Dejar SMTP_HOST vacio desactiva el envio.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_STARTTLS=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_FROM_NAME=CRM FiNet
