# Copiar como .env.railway. El archivo real queda ignorado por Git.
# Desde Docker local se debe usar la URL publica/TCP Proxy de Railway,
# no el hostname privado *.railway.internal.
DATABASE_URL=postgresql://postgres:REEMPLAZAR_PASSWORD@REEMPLAZAR_HOST_PROXY:REEMPLAZAR_PUERTO/railway?schema=public

JWT_SECRET=change_me_in_local_env
JWT_EXPIRES_IN=8h

# Puertos alternativos para poder ejecutar el stack local y Railway a la vez.
RAILWAY_BACKEND_PORT=3001
RAILWAY_FRONTEND_PORT=5174
VITE_API_URL=/api

# Correo de cotizaciones (SMTP). Usar credenciales del proveedor autorizado.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_STARTTLS=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_FROM_NAME=CRM FiNet
